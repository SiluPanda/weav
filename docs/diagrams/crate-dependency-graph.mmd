%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#1a1a2e', 'primaryTextColor': '#e0e0e0', 'primaryBorderColor': '#4a4a6a', 'lineColor': '#6c63ff', 'secondaryColor': '#16213e', 'tertiaryColor': '#0f3460', 'background': '#0d1117', 'mainBkg': '#161b22', 'nodeBorder': '#30363d', 'clusterBkg': '#161b22', 'clusterBorder': '#30363d', 'titleColor': '#e0e0e0', 'edgeLabelBackground': '#161b22'}}}%%
graph TD
    subgraph Foundation
        CORE["weav-core\n<i>types, errors, config,\nshard, context, events</i>"]
    end

    subgraph Data Layer
        GRAPH["weav-graph\n<i>adjacency, properties,\ntext index, 40+ algorithms</i>"]
        VECTOR["weav-vector\n<i>HNSW index, token counting</i>\n⚙ optional"]
        PERSIST["weav-persist\n<i>WAL, snapshots, recovery</i>"]
    end

    subgraph Intelligence Layer
        QUERY["weav-query\n<i>parser, planner,\nexecutor, budget</i>"]
        EXTRACT["weav-extract\n<i>PDF/DOCX, LLM extraction,\nchunking, embeddings</i>\n⚙ optional"]
        AUTH["weav-auth\n<i>ACL, API keys, Argon2id</i>"]
    end

    subgraph Interface Layer
        PROTO["weav-proto\n<i>RESP3 codec, gRPC proto</i>\n⚙ optional"]
        SERVER["weav-server\n<i>HTTP/axum, engine coordinator</i>"]
        CLI["weav-cli\n<i>interactive REPL</i>"]
        MCP["weav-mcp\n<i>28 MCP tools</i>"]
    end

    CORE --> GRAPH
    CORE --> VECTOR
    CORE --> PERSIST
    CORE --> AUTH
    CORE --> QUERY
    CORE --> PROTO

    GRAPH --> QUERY
    GRAPH --> EXTRACT
    VECTOR -.->|"⚙ feature: vector"| QUERY

    QUERY --> PROTO
    QUERY --> SERVER

    CORE --> SERVER
    GRAPH --> SERVER
    VECTOR -.->|"⚙ feature: vector"| SERVER
    PERSIST --> SERVER
    AUTH --> SERVER
    EXTRACT -.->|"⚙ feature: extract"| SERVER
    PROTO -.->|"⚙ feature: resp3/grpc"| SERVER

    SERVER --> CLI
    SERVER --> MCP

    classDef foundation fill:#1a1a2e,stroke:#6c63ff,color:#e0e0e0,stroke-width:2px
    classDef data fill:#16213e,stroke:#4a9eff,color:#e0e0e0,stroke-width:2px
    classDef intel fill:#0f3460,stroke:#00d2ff,color:#e0e0e0,stroke-width:2px
    classDef iface fill:#1a1a2e,stroke:#ff6b6b,color:#e0e0e0,stroke-width:2px
    classDef optional fill:#16213e,stroke:#ffd93d,color:#e0e0e0,stroke-dasharray:5 5

    class CORE foundation
    class GRAPH,PERSIST data
    class VECTOR optional
    class QUERY,AUTH intel
    class EXTRACT optional
    class PROTO optional
    class SERVER,CLI,MCP iface
