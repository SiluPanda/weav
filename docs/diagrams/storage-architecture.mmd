%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#1a1a2e', 'primaryTextColor': '#e0e0e0', 'primaryBorderColor': '#4a4a6a', 'lineColor': '#6c63ff', 'secondaryColor': '#16213e', 'tertiaryColor': '#0f3460', 'background': '#0d1117', 'mainBkg': '#161b22', 'nodeBorder': '#30363d', 'clusterBkg': '#161b22', 'clusterBorder': '#30363d', 'titleColor': '#e0e0e0', 'edgeLabelBackground': '#161b22'}}}%%
graph TB
    subgraph "Engine (RwLock&lt;HashMap&lt;String, Arc&lt;RwLock&lt;GraphState&gt;&gt;&gt;&gt;)"

        subgraph GS1["GraphState: 'knowledge'"]
            ADJ1["AdjacencyStore\n• forward: HashMap&lt;LabelId, DirectedAdjacency&gt;\n• backward: HashMap&lt;LabelId, DirectedAdjacency&gt;\n• edge_meta: HashMap&lt;EdgeId, EdgeMeta&gt;\n• pair_index: HashMap&lt;(Src,Tgt), SmallVec&lt;EdgeId&gt;&gt;\n• node_bitmap: RoaringTreemap"]
            PROP1["PropertyStore\n• node_properties: HashMap&lt;NodeId, Vec&lt;(Key,Value)&gt;&gt;\n• edge_properties: HashMap&lt;EdgeId, Vec&lt;(Key,Value)&gt;&gt;\n• property_index: HashMap&lt;key, HashMap&lt;val, Vec&lt;NodeId&gt;&gt;&gt;"]
            VEC1["VectorIndex (HNSW)\n• usearch Index (m=16, ef=200)\n• node ↔ key bidirectional maps\n• raw vectors: HashMap&lt;NodeId, Vec&lt;f32&gt;&gt;"]
            TXT1["TextIndex (BM25)\n• inverted index\n• term frequencies\n• document lengths"]
            INT1["StringInterner\n• label ↔ LabelId (u16)\n• property_key ↔ PropertyKeyId (u16)"]
        end

        subgraph GS2["GraphState: 'users'"]
            ADJ2["AdjacencyStore"]
            PROP2["PropertyStore"]
            VEC2["VectorIndex"]
        end
    end

    subgraph "Persistence Layer"
        WAL["Write-Ahead Log\n• Append-only file\n• [u32 len][bincode entry]\n• CRC32 per entry\n• Sync: Always / EverySecond / Never"]
        SNAP["Snapshot Engine\n• Full state serialization (bincode)\n• SnapshotMeta: timestamp, version, checksum\n• Interval: 3600s default"]
    end

    GS1 -.->|"writes"| WAL
    GS2 -.->|"writes"| WAL
    SNAP -.->|"reads all"| GS1
    SNAP -.->|"reads all"| GS2
    WAL -.->|"recovery replay"| GS1
    SNAP -.->|"recovery restore"| GS1

    classDef graphstate fill:#16213e,stroke:#4a9eff,color:#e0e0e0
    classDef persist fill:#0f3460,stroke:#ffd93d,color:#e0e0e0
    classDef store fill:#1a1a2e,stroke:#6c63ff,color:#e0e0e0

    class GS1,GS2 graphstate
    class WAL,SNAP persist
    class ADJ1,PROP1,VEC1,TXT1,INT1,ADJ2,PROP2,VEC2 store
