%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#1a1a2e', 'primaryTextColor': '#e0e0e0', 'primaryBorderColor': '#4a4a6a', 'lineColor': '#6c63ff', 'secondaryColor': '#16213e', 'tertiaryColor': '#0f3460', 'background': '#0d1117', 'mainBkg': '#161b22', 'nodeBorder': '#30363d', 'titleColor': '#e0e0e0', 'edgeLabelBackground': '#161b22'}}}%%
flowchart TD
    START(["CONTEXT Query"]) --> SEEDS

    subgraph "Step 1: Seed Acquisition"
        SEEDS{Seed Strategy}
        SEEDS -->|Vector| VS["HNSW Search\ntop-k nearest neighbors"]
        SEEDS -->|Nodes| NK["Entity Key Lookup\nproperty scan"]
        SEEDS -->|Both| BOTH["Vector + Node Keys\nunion with dedup"]
    end

    VS --> SCORED["Scored Seeds\nVec<(NodeId, f32)>"]
    NK --> SCORED
    BOTH --> SCORED

    SCORED --> FLOW

    subgraph "Step 2: Graph Propagation"
        FLOW["Flow Score\npersonalized PageRank\nalpha=0.5, theta=0.01"]
    end

    FLOW --> BM25

    subgraph "Step 3: Triple-Fusion RRF"
        BM25["BM25 Text Search\n(if query_text present)"]
        BM25 --> RRF["Reciprocal Rank Fusion\nk=60, weights=[1.0, 1.0, 0.8]"]
        FLOW --> RRF
    end

    RRF --> CHUNKS

    subgraph "Step 4: Chunk Building"
        CHUNKS["Build ContextChunks\nproperties, labels, tokens"]
        CHUNKS --> TEMPORAL["Temporal Filter\n(if temporal_at set)"]
        TEMPORAL --> DECAY["Apply Decay Function\nexponential / linear / step"]
        DECAY --> CONFLICT["Conflict Detection\ncompare property values"]
    end

    CONFLICT --> BUDGET

    subgraph "Step 5: Budget Enforcement"
        BUDGET{"Token Budget\nStrategy"}
        BUDGET -->|Greedy| GREEDY["Sort by value-density\nrelevance / token_count"]
        BUDGET -->|MMR| MMR["Maximum Marginal\nRelevance (diversity)"]
        BUDGET -->|Submodular| SUB["Facility Location\ncoverage optimization"]
    end

    GREEDY --> RELS
    MMR --> RELS
    SUB --> RELS

    subgraph "Step 6: Enrichment"
        RELS["Build RelationshipSummary\nedge labels, targets, weights"]
        RELS --> SORT["Apply Sort Order\nrelevance / recency / confidence"]
        SORT --> FMT["Format Output\nraw / anthropic / openai"]
    end

    FMT --> RESULT(["ContextResult\nchunks, timing, conflicts,\nsubgraph, formatted_messages"])

    classDef step fill:#16213e,stroke:#4a9eff,color:#e0e0e0
    classDef decision fill:#0f3460,stroke:#ffd93d,color:#e0e0e0
    classDef result fill:#1a1a2e,stroke:#6c63ff,color:#e0e0e0

    class VS,NK,BOTH,FLOW,BM25,RRF,CHUNKS,TEMPORAL,DECAY,CONFLICT,GREEDY,MMR,SUB,RELS,SORT,FMT step
    class SEEDS,BUDGET decision
    class START,RESULT,SCORED result
