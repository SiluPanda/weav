flowchart LR
    DOC(["Document\nPDF / DOCX / CSV / Text"]) --> PARSE

    subgraph "weav-extract"
        PARSE["Document Parser\npdf_oxide / zip\n⚙ feature: pdf"] --> CHUNK["Text Chunker\ntext-splitter\nrecursive split"]
        CHUNK --> EMBED["Chunk Embeddings\nbatched, concurrent\nLLM API calls"]
        EMBED --> ENTITY["Entity Extraction\nLLM JSON extraction\nbatched by token limit\n⚙ feature: llm-providers"]
        ENTITY --> DEDUP["Entity Dedup\nJaro-Winkler fuzzy match\nthreshold: 0.85"]
        DEDUP --> RELEMBED["Entity Embeddings\ndescription → vector"]
        RELEMBED --> RELDEDUP["Relationship Dedup\nby (source, target, type)"]
    end

    RELDEDUP --> RESULT

    subgraph "weav-server (Engine)"
        RESULT["ExtractionResult"] --> NODES["Create Nodes\nentity_key, label,\nproperties, embedding"]
        NODES --> EDGES["Create Edges\nrelationship type,\nweight, properties"]
        EDGES --> INDEX["Index Updates\nHNSW insert\nBM25 index\nProperty index"]
    end

    classDef input fill:#1a1a2e,stroke:#6c63ff,color:#e0e0e0
    classDef extract fill:#16213e,stroke:#4a9eff,color:#e0e0e0
